# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_NAME=MyApp
APP_VERSION=0.1.0
# Set to true to enable FastAPI debug mode and auto-reload
DEBUG=false
# One of: development, staging, production
ENVIRONMENT=development

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Async PostgreSQL URL — must use asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/myapp

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Set to true to echo all SQL statements (useful for debugging)
DB_ECHO=false

# ──────────────────────────────────────────────
# Security — JWT
# ──────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-secure-random-string
JWT_ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# Security — Default Admin User (auto-seeded on startup if no admin exists)
# ──────────────────────────────────────────────
# Email for the default admin account
ADMIN_EMAIL=admin@sentry.local
# Username for the default admin account
ADMIN_USERNAME=admin
# First name for the default admin account
ADMIN_FIRST_NAME=System
# Last name for the default admin account
ADMIN_LAST_NAME=Admin
# Password for the default admin account (REQUIRED — choose a strong password)
ADMIN_PASSWORD=change-me-to-a-strong-password

# ──────────────────────────────────────────────
# Security — Token Cleanup
# ──────────────────────────────────────────────
# Interval (in seconds) between expired-token cleanup sweeps (dashboard JWTs)
TOKEN_CLEANUP_INTERVAL_SECONDS=3600

# ──────────────────────────────────────────────
# Security — Extension install tokens
# ──────────────────────────────────────────────
# Lifetime of an extension install token (days) — the extension silently renews within 5 days of expiry
EXTENSION_TOKEN_EXPIRE_DAYS=30
# Interval (seconds) between expired extension-token cleanup sweeps
EXTENSION_TOKEN_CLEANUP_INTERVAL_SECONDS=3600

# ──────────────────────────────────────────────
# Server — CORS (dashboard origins)
# ──────────────────────────────────────────────
# Comma-separated list of allowed origins. Do NOT use "*" when CORS_ALLOW_CREDENTIALS=true —
# browsers reject that pair. Use specific origins like http://localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
# Comma-separated list of allowed HTTP methods, or * for all
CORS_ALLOW_METHODS=*
# Comma-separated list of allowed headers, or * for all
CORS_ALLOW_HEADERS=*
# Regex matching additional origins (e.g. chrome-extension://<id>). Leave default unless
# you need a different pattern.
CORS_ORIGIN_REGEX=^chrome-extension://[A-Za-z0-9_-]+$

# ──────────────────────────────────────────────
# Server — Rate limits (extension surface)
# ──────────────────────────────────────────────
# slowapi expressions — e.g. "3/minute", "100/hour"
RATE_LIMIT_EXTENSION_REGISTER=3/minute
RATE_LIMIT_EXTENSION_RENEW=10/minute
RATE_LIMIT_EXTENSION_PREDICT=60/minute

# ──────────────────────────────────────────────
# Extension — CORS widen + allow/block lists + Google OAuth
# ──────────────────────────────────────────────
# Comma-separated extra origins for extension endpoints only
# chrome-extension://<id> is matched by regex automatically — add https://mail.google.com here.
EXTENSION_CORS_ORIGINS=https://mail.google.com
# Comma-separated allow-list domains (empty = allow all) — e.g. company.com,partner.com
EXTENSION_ALLOWLIST_DOMAINS=
# Comma-separated allow-list individual emails — e.g. user@example.com
EXTENSION_ALLOWLIST_EMAILS=
# Comma-separated blocklist domains — rejected at register and on every protected call
EXTENSION_BLOCKLIST_DOMAINS=
# Comma-separated blocklist emails
EXTENSION_BLOCKLIST_EMAILS=
# Google OAuth client id used by the extension (optional — only needed for tokeninfo audience check)
EXTENSION_GOOGLE_OAUTH_CLIENT_ID=

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Path to the log file (directory will be created if it does not exist)
LOG_FILE_PATH=logs/app.log

# ──────────────────────────────────────────────
# Inference — Groq (Stage 1 email classification)
# ──────────────────────────────────────────────
# Groq API key — get one at https://console.groq.com/keys (REQUIRED)
GROQ_API_KEY=replace-with-your-groq-api-key
# Groq model used for email classification
GROQ_MODEL=llama-3.1-8b-instant
# Hard timeout (seconds) per Groq API call
GROQ_TIMEOUT_SECONDS=30

# ──────────────────────────────────────────────
# Inference — Gemini (Stage 3 batched page analysis)
# ──────────────────────────────────────────────
# Google AI Studio API key — get one at https://aistudio.google.com/apikey (REQUIRED)
GEMINI_API_KEY=replace-with-your-gemini-api-key
# Gemini model used for batched page summarization
GEMINI_MODEL=gemini-1.5-flash
# Hard timeout (seconds) per Gemini API call
GEMINI_TIMEOUT_SECONDS=60

# ──────────────────────────────────────────────
# Inference — Scraping (Stage 2 link resolution + page scrape)
# ──────────────────────────────────────────────
# Hard timeout (seconds) for plain httpx GET (Attempt 1)
SCRAPE_ATTEMPT_1_TIMEOUT=5
# Hard timeout (seconds) for httpx with browser User-Agent (Attempt 2)
SCRAPE_ATTEMPT_2_TIMEOUT=8
# Hard timeout (seconds) for Playwright headless browser (Attempt 3)
SCRAPE_ATTEMPT_3_TIMEOUT=15
# User-Agent header sent on Attempt 2 / page scraping
SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36
# Maximum characters of cleaned page text sent to the Stage 3 LLM per page
SCRAPE_CONTENT_CHAR_CAP=1000

# ──────────────────────────────────────────────
# Inference — Pipeline (orchestration tuning)
# ──────────────────────────────────────────────
# Confidence threshold for the early-exit rule (skip Stages 2/3 when met)
EARLY_EXIT_CONFIDENCE=0.85
# Maximum number of emails accepted in a single POST /emails/batch call
INFERENCE_BATCH_MAX=50
# Maximum concurrent link-resolution tasks per email (asyncio.Semaphore size)
INFERENCE_MAX_CONCURRENCY=10

# ──────────────────────────────────────────────
# Inference — Extension analyse endpoint
# ──────────────────────────────────────────────
# Phishing-probability cutoff for should_alert=true in POST /api/v1/emails/analyze
INFERENCE_ALERT_THRESHOLD=0.90
# Max bytes for the projected email body sent to the detector — exceeding this returns 400 BAD_REQUEST
INFERENCE_EMAILS_MAX_BODY_BYTES=102400
